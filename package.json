{
  "name": "futbol-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Europe's top-8 leagues + UEFA Champions League dashboard (React + TypeScript + Vite)",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && cp dist/index.html dist/404.html",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "ingest": "node scripts/ingest-football-data.mjs",
    "ingest:live": "node scripts/ingest-espn-live.mjs",
    "ingest:live:check": "node scripts/ingest-espn-live.mjs --check",
    "ingest:fotmob": "node scripts/ingest-fotmob.mjs",
    "ingest:fotmob:check": "node scripts/ingest-fotmob.mjs --check"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
